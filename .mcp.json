{
  "mcpServers": {
    "trusty-memory": {
      "type": "stdio",
      "command": "trusty-memory",
      "args": [
        "serve",
        "--palace",
        "claude-mpm"
      ]
    },
    "trusty-search": {
      "type": "stdio",
      "command": "trusty-search",
      "args": [
        "serve"
      ]
    },
    "mcp-ticketer": {
      "type": "stdio",
      "command": "mcp-ticketer",
      "args": [
        "mcp",
        "--path",
        "/Users/masa/Projects/claude-mpm"
      ],
      "env": {}
    },
    "mcp-skillset": {
      "type": "stdio",
      "command": "mcp-skillset",
      "args": [
        "mcp"
      ],
      "env": {}
    },
    "slack-user-proxy": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/masa/Projects/claude-mpm",
        "claude-mpm",
        "mcp",
        "serve",
        "slack-proxy"
      ],
      "env": {}
    },
    "gworkspace-mcp": {
      "type": "stdio",
      "command": "gworkspace-mcp",
      "args": [
        "mcp"
      ]
    },
    "mpm-messaging": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/masa/Projects/claude-mpm",
        "claude-mpm",
        "mcp",
        "serve",
        "messaging"
      ],
      "env": {}
    }
  }
}
