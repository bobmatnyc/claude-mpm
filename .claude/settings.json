{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15,
            "_mpm": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15,
            "_mpm": true
          }
        ]
      },
      {
        "matcher": "Write|MultiEdit|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "-m",
              "claude_mpm.hooks.trusty_index_hook"
            ],
            "timeout": 10,
            "async": true,
            "_mpm": true,
            "_mpm_service": "trusty-search"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "-m",
              "claude_mpm.hooks.tool_failure_hook"
            ],
            "timeout": 5,
            "_mpm": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "_mpm": true,
            "timeout": 15,
            "_mpm_service": "trusty-memory"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "_mpm": true,
            "timeout": 15,
            "_mpm_service": "trusty-memory"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "_mpm": true,
            "timeout": 15,
            "_mpm_service": "trusty-memory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15,
            "_mpm": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "-m",
              "claude_mpm.hooks.message_check_hook"
            ],
            "timeout": 10,
            "_mpm": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15,
            "_mpm": true
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude MPM <https://github.com/bobmatnyc/claude-mpm>",
    "pr": "Generated with [Claude MPM](https://github.com/bobmatnyc/claude-mpm)"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Orchestrating agents",
      "Delegating tasks",
      "Routing to specialist",
      "Checking circuit breakers",
      "Querying memory",
      "Planning workflow",
      "Analyzing codebase",
      "Coordinating subagents",
      "Applying best practices",
      "Thinking"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "Use /compact at ~50% context to stay sharp",
      "Start with plan mode for complex orchestration tasks",
      "One file per commit keeps history clean",
      "Delegate to specialist agents \u2014 PM never edits code directly",
      "Use trusty-memory to persist decisions across sessions",
      "Circuit breakers protect against runaway delegation chains",
      "Feature-specific subagents outperform general-purpose agents",
      "Skills preload context without consuming prompt tokens unnecessarily"
    ],
    "excludeDefault": true
  },
  "permissions": {
    "additionalDirectories": [],
    "allow": [
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(aws ssm get-command-invocation *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt --check *)"
    ]
  },
  "autoMemoryEnabled": true,
  "_mpm_managed": true,
  "_mpm_version": "6.3.2"
}
