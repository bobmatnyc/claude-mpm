{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m claude_mpm.hooks.model_tier_hook",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m claude_mpm.hooks.ztk_hook",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m claude_mpm.hooks.context_circuit_breaker",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 60
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m claude_mpm.hooks.model_tier_hook",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude MPM <https://github.com/bobmatnyc/claude-mpm>",
    "pr": "Generated with [Claude MPM](https://github.com/bobmatnyc/claude-mpm)"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Orchestrating agents",
      "Delegating tasks",
      "Routing to specialist",
      "Checking circuit breakers",
      "Querying memory",
      "Planning workflow",
      "Analyzing codebase",
      "Coordinating subagents",
      "Applying best practices",
      "Thinking"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "Use /compact at ~50% context to stay sharp",
      "Start with plan mode for complex orchestration tasks",
      "One file per commit keeps history clean",
      "Delegate to specialist agents — PM never edits code directly",
      "Use kuzu-memory to persist decisions across sessions",
      "Circuit breakers protect against runaway delegation chains",
      "Feature-specific subagents outperform general-purpose agents",
      "Skills preload context without consuming prompt tokens unnecessarily"
    ],
    "excludeDefault": true
  },
  "permissions": {
    "additionalDirectories": []
  },
  "autoMemoryEnabled": true,
  "_mpm_managed": true,
  "_mpm_version": "6.3.2"
}
