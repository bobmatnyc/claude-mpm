{
  "_mpm_managed": true,
  "_mpm_version": "6.3.19",
  "autoMemoryEnabled": true,
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/scripts/statusline.sh",
    "padding": 1,
    "refreshInterval": 10
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["-m", "claude_mpm.hooks.tool_failure_hook"],
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-fast.sh StopFailure",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-fast.sh SessionEnd",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["-m", "claude_mpm.hooks.message_check_hook"],
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-fast.sh PostCompact",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Orchestrating agents",
      "Delegating tasks",
      "Routing to specialist",
      "Checking circuit breakers",
      "Querying memory",
      "Planning workflow",
      "Analyzing codebase",
      "Coordinating subagents",
      "Applying best practices",
      "Thinking"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "Use /compact at ~50% context to stay sharp",
      "Start with plan mode for complex orchestration tasks",
      "One file per commit keeps history clean",
      "Delegate to specialist agents — PM never edits code directly",
      "Use kuzu-memory to persist decisions across sessions",
      "Circuit breakers protect against runaway delegation chains",
      "Feature-specific subagents outperform general-purpose agents",
      "Skills preload context without consuming prompt tokens"
    ],
    "excludeDefault": true
  }
}
